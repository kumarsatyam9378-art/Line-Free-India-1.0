rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isVerified() { return isAuth() && request.auth.token.email_verified == true; }

    // In our logic for backwards compat, a user can either be a business owner
    // or a customer. The rules check if auth.uid matches the required ID.

    // Businesses (Public read, owner write)
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }
    match /salons/{businessId} {
      allow read: if true;
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }
    match /barbers/{businessId} {
      allow read: if true;
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }

    // Business sub-collections (Staff/Jobs/etc) (Owner write)
    match /businesses/{businessId}/{subcollection}/{docId} {
      allow read: if isAuth();
      allow write: if isOwner(businessId);
    }
    match /salons/{businessId}/{subcollection}/{docId} {
      allow read: if isAuth();
      allow write: if isOwner(businessId);
    }
    match /barbers/{businessId}/{subcollection}/{docId} {
      allow read: if isAuth();
      allow write: if isOwner(businessId);
    }

    // Bookings / Tokens (Auth users can create, only involved parties can read/update)
    match /bookings/{bookingId} {
      allow create: if isAuth() && (
        request.resource.data.customerId == request.auth.uid ||
        request.resource.data.businessId == request.auth.uid
      );
      allow read, update, delete: if isAuth() && (
        resource.data.businessId == request.auth.uid ||
        resource.data.customerId == request.auth.uid
      );
    }
    match /tokens/{bookingId} {
      allow create: if isAuth() && (
        request.resource.data.customerId == request.auth.uid ||
        request.resource.data.salonId == request.auth.uid ||
        request.resource.data.businessId == request.auth.uid
      );
      allow read, update, delete: if isAuth() && (
        resource.data.salonId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        resource.data.businessId == request.auth.uid
      );
    }

    // Customers (Owner only)
    match /customers/{customerId} {
      allow read, write: if isOwner(customerId);
    }

    // Reviews (Public read, verified users create)
    match /reviews/{reviewId} {
      allow read: if true;
      // Note: Assuming standard Firebase Auth email verified. Google Sign-In makes email_verified true.
      allow create: if isVerified() && request.resource.data.customerId == request.auth.uid;
      // Only author can update/delete
      allow update, delete: if isAuth() && resource.data.customerId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Chat Messages
    match /messages/{messageId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        resource.data.salonId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.senderId == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
